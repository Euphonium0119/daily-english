# 每日英语外刊推送 — 环境变量配置
# 复制此文件为 .env 并填入真实值

# NewsAPI — https://newsapi.org/register
NEWS_API_KEY=your_news_api_key_here

# DeepSeek API — https://platform.deepseek.com/
DEEPSEEK_API_KEY=your_deepseek_api_key_here

# QQ 邮箱 SMTP
SMTP_USER=your_qq_email@qq.com
SMTP_PASS=your_smtp_authorization_code
TO_EMAIL=receiver_email@qq.com

# NewsAPI 新闻源（可选，默认使用 6 个主要英文新闻源）
# NEWS_SOURCES=bbc-news,cnn,the-guardian-uk,reuters,associated-press,abc-news
